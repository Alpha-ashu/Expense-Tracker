{
  "version": 2,
  "name": "expense-tracker",
  "buildCommand": "npm run project:build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "maxDuration": 30,
      "includeFiles": "backend/{dist,prisma,generated}/**"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "status": 404
    },
    {
      "src": "/api/v1/stocks$",
      "dest": "api/stocks.ts"
    },
    {
      "src": "/api/v1/stocks/(.*)",
      "dest": "api/stocks.ts?endpoint=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/health",
      "dest": "api/health.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_VERSION": "18.x",
    "SUPABASE_URL": "https://mmwrckfqeqjfqciymemh.supabase.co",
    "SUPABASE_ANON_KEY": "sb_publishable_QA4aNzLgHR9xanXUJaPpew_XGRicYBq",
    "VITE_SUPABASE_URL": "https://mmwrckfqeqjfqciymemh.supabase.co",
    "VITE_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_QA4aNzLgHR9xanXUJaPpew_XGRicYBq",
    "DATABASE_URL": "postgresql://postgres:Alpha_Ashu%401@db.mmwrckfqeqjfqciymemh.supabase.co:5432/postgres"
  },
  "regions": [
    "iad1"
  ]
}
